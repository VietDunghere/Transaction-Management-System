// ============================================================
// Transaction Management System — DBML for dbdiagram.io
// Source: backend/db/ERD.sql
// ============================================================

// ============================================================
// GROUP: Core — Identity & Master Data
// ============================================================

TableGroup core {
  users
  roles
  user_roles
  customers
  merchants
  channels
}

Table users {
  user_id       varchar(36)  [pk, note: 'UUID']
  username      varchar(100) [not null, unique]
  password_hash varchar(255) [not null]
  full_name     varchar(150)
  email         varchar(150) [unique]
  is_active     int          [not null, default: 1, note: '1=active 0=inactive']
  created_at    timestamp    [not null]
  updated_at    timestamp
}

Table roles {
  role_id   int         [pk, increment, note: 'GENERATED AS IDENTITY']
  role_name varchar(50) [not null, unique, note: 'OPERATOR|REVIEWER|ANALYST|MANAGER|ADMIN']
}

Table user_roles {
  user_id     varchar(36) [not null, ref: > users.user_id]
  role_id     int         [not null, ref: > roles.role_id]
  assigned_at timestamp   [not null]

  indexes {
    (user_id, role_id) [pk]
  }
}

Table customers {
  customer_id     varchar(36)   [pk, note: 'UUID']
  customer_code   varchar(50)   [unique]
  kyc_status      varchar(20)
  full_name       varchar(150)
  identity_card   varchar(50)   [unique]
  address         varchar(255)
  city            varchar(100)
  state           varchar(50)
  zip_code        varchar(20)
  gender          varchar(10)
  date_of_birth   date
  job             varchar(150)
  latitude        decimal(9,6)
  longitude       decimal(9,6)
  city_population int
  income_level    varchar(50)
  created_at      timestamp     [not null]
}

Table merchants {
  merchant_id       varchar(36)  [pk, note: 'UUID']
  merchant_code     varchar(50)  [not null, unique]
  merchant_name     varchar(150) [not null]
  merchant_category varchar(100)
  city              varchar(100)
  state             varchar(50)
  country           varchar(100)
  latitude          decimal(9,6)
  longitude         decimal(9,6)
  risk_level        varchar(20)
  is_blacklisted    int          [not null, default: 0]
  created_at        timestamp    [not null]
}

Table channels {
  channel_id   int         [pk, increment, note: 'GENERATED AS IDENTITY']
  channel_code varchar(50) [not null, unique]
  channel_name varchar(100) [not null]
}

// ============================================================
// GROUP: Transactions — OLTP Core Flow
// ============================================================

TableGroup transactions {
  transactions_live
  txn_state
  txn_state_history
  txn_idempotency
  risk_scoring_results
  rule_hits
}

Table transactions_live {
  txn_id             varchar(36)   [pk, note: 'UUID']
  customer_id        varchar(36)   [not null, ref: > customers.customer_id]
  merchant_id        varchar(36)   [not null, ref: > merchants.merchant_id]
  channel_id         int           [not null, ref: > channels.channel_id]
  submitted_by       varchar(36)   [not null, ref: > users.user_id]
  card_number_masked varchar(30)
  card_number_hash   varchar(64)   [note: 'SHA256 — không lưu số thẻ raw']
  amount             decimal(18,2) [not null, note: '> 0']
  currency_code      varchar(10)   [not null, default: 'USD']
  txn_time           timestamp     [not null]
  status             varchar(20)   [not null, note: 'PENDING|APPROVED|REJECTED|MANUAL_REVIEW']
  fraud_score        decimal(6,4)  [note: '0.0–1.0']
  reason_code        varchar(50)
  override_reason    varchar(50)
  source_ip          varchar(64)
  merch_lat          decimal(9,6)
  merch_long         decimal(9,6)
  unix_time          int
  created_at         timestamp     [not null]
  updated_at         timestamp

  indexes {
    status      [name: 'idx_transactions_status']
    txn_time    [name: 'idx_txn_live_time']
    customer_id [name: 'idx_txn_live_cust']
    merchant_id [name: 'idx_txn_live_merch']
    channel_id  [name: 'idx_txn_live_chan']
    card_number_hash [name: 'idx_txn_live_card_hash']
    submitted_by     [name: 'idx_txn_live_submitted']
  }
}

Table txn_state {
  txn_id             varchar(36)  [pk, ref: - transactions_live.txn_id]
  status             varchar(20)  [not null, note: 'PENDING|APPROVED|REJECTED|MANUAL_REVIEW']
  last_update        timestamp    [not null]
  reason_code        varchar(50)
  retry_count        int          [not null, default: 0]
  last_error_code    varchar(50)
  last_error_message varchar(500)
  version            int          [not null, default: 1, note: 'Optimistic Locking']
}

Table txn_state_history {
  state_hist_id      varchar(36) [pk, note: 'UUID']
  txn_id             varchar(36) [not null, ref: > transactions_live.txn_id]
  old_status         varchar(20)
  new_status         varchar(20) [not null]
  changed_by_user_id varchar(36) [ref: > users.user_id]
  changed_at         timestamp   [not null]
  change_reason      varchar(200)

  indexes {
    txn_id [name: 'idx_txn_state_history_txn']
  }
}

Table txn_idempotency {
  idempotency_key        varchar(100) [pk]
  txn_hash               varchar(128)
  txn_id                 varchar(36)  [ref: > transactions_live.txn_id]
  status                 varchar(20)  [not null, note: 'IN_PROGRESS|SUCCESS|FAILED']
  response_snapshot_json varchar(4000)
  created_at             timestamp    [not null]
  updated_at             timestamp
}

Table risk_scoring_results {
  score_id              varchar(36)  [pk, note: 'UUID']
  txn_id                varchar(36)  [not null, ref: > transactions_live.txn_id]
  model_version         varchar(50)
  fraud_score           decimal(6,4) [not null, note: '0.0–1.0']
  decision_suggested    varchar(20)
  reason_json           text
  reject_threshold      decimal(6,4) [note: 'Ngưỡng REJECT snapshot tại thời điểm score']
  review_threshold      decimal(6,4) [note: 'Ngưỡng MANUAL_REVIEW snapshot']
  feature_snapshot_json text
  score_time            timestamp    [not null]

  indexes {
    txn_id     [name: 'idx_risk_txn_id']
    score_time [name: 'idx_risk_score_time']
  }
}

Table rule_hits {
  rule_hit_id varchar(36)  [pk, note: 'UUID']
  txn_id      varchar(36)  [not null, ref: > transactions_live.txn_id]
  rule_code   varchar(50)  [not null]
  rule_name   varchar(150)
  hit_value   varchar(255)
  severity    varchar(20)
  created_at  timestamp    [not null]

  indexes {
    rule_code [name: 'idx_rule_hits_code']
  }
}

// ============================================================
// GROUP: Cases — Manual Review Workflow
// ============================================================

TableGroup cases {
  review_cases
  review_case_actions
}

Table review_cases {
  case_id       varchar(36)   [pk, note: 'UUID']
  txn_id        varchar(36)   [not null, unique, ref: > transactions_live.txn_id]
  case_status   varchar(20)   [not null, note: 'OPEN|ASSIGNED|APPROVED|REJECTED|CLOSED']
  assigned_to   varchar(36)   [ref: > users.user_id]
  decision      varchar(20)
  decision_note varchar(2000)
  version       int           [not null, default: 1, note: 'Optimistic Locking']
  created_at    timestamp     [not null]
  decided_at    timestamp

  indexes {
    case_status [name: 'idx_case_status']
    assigned_to [name: 'idx_case_assigned']
  }
}

Table review_case_actions {
  action_id     varchar(36)  [pk, note: 'UUID']
  case_id       varchar(36)  [not null, ref: > review_cases.case_id]
  action_type   varchar(30)  [not null, note: 'ASSIGN|COMMENT|APPROVE|REJECT|REOPEN']
  actor_user_id varchar(36)  [not null, ref: > users.user_id]
  action_note   varchar(500)
  created_at    timestamp    [not null]

  indexes {
    case_id [name: 'idx_review_case_actions_case']
  }
}

// ============================================================
// GROUP: Loans — Credit Lifecycle
// ============================================================

TableGroup loans_group {
  loans
}

Table loans {
  loan_id                    varchar(36)   [pk, note: 'UUID']
  customer_id                varchar(36)   [not null, ref: > customers.customer_id]
  submitted_by               varchar(36)   [not null, ref: > users.user_id, note: 'OPERATOR']
  reviewed_by                varchar(36)   [ref: > users.user_id, note: 'REVIEWER']
  principal_amount           decimal(18,2) [not null, note: '> 0']
  currency_code              varchar(10)   [not null, default: 'USD']
  interest_rate              decimal(6,4)  [not null, note: '0 < rate < 100']
  term_months                int           [not null]
  purpose                    varchar(200)
  status                     varchar(20)   [not null, note: 'PENDING|APPROVED|REJECTED|DISBURSED|CLOSED|DEFAULTED']
  version                    int           [not null, default: 1, note: 'Optimistic Locking']
  review_note                varchar(500)
  reviewed_at                timestamp
  monthly_payment            decimal(18,2)
  outstanding_balance        decimal(18,2)
  disbursed_at               timestamp
  maturity_date              date
  person_age                 int
  person_income              decimal(18,2)
  person_home_ownership      varchar(20)   [note: 'RENT|MORTGAGE|OWN|OTHER']
  person_emp_length          int
  loan_grade                 varchar(2)    [note: 'A-G']
  loan_intent                varchar(30)
  cb_person_default_on_file  varchar(1)    [note: 'Y|N']
  cb_person_cred_hist_length int
  pd_score                   decimal(6,4)  [note: '0.0–1.0 xác suất vỡ nợ']
  risk_level                 varchar(20)   [note: 'LOW RISK|MEDIUM RISK|HIGH RISK']
  created_at                 timestamp     [not null]
  updated_at                 timestamp

  indexes {
    status      [name: 'idx_loans_status']
    customer_id [name: 'idx_loans_customer']
    submitted_by [name: 'idx_loans_submitted']
    reviewed_by  [name: 'idx_loans_reviewed_by']
  }
}

// ============================================================
// GROUP: Analyst — Thresholds, Suppression, Reports
// ============================================================

TableGroup analyst {
  model_configs
  suppression_rules
  analyst_reports
}

Table model_configs {
  config_id   int          [pk, increment, note: 'GENERATED AS IDENTITY']
  model_name  varchar(50)  [not null, note: '"fraud" | "loan"']
  param_name  varchar(100) [not null, note: '"reject_threshold"|"review_threshold"|"high_risk_threshold"|"medium_risk_threshold"']
  param_value decimal(10,6) [not null]
  description varchar(255)
  updated_by  varchar(36)  [ref: > users.user_id]
  updated_at  timestamp    [not null]
  version     int          [not null, default: 1]

  indexes {
    (model_name, param_name) [unique, name: 'uq_model_configs_name_param']
  }
}

Table suppression_rules {
  rule_id    varchar(36)  [pk, note: 'UUID']
  rule_type  varchar(20)  [not null, note: 'MERCHANT|CUSTOMER|CARD_HASH']
  entity_id  varchar(255) [not null]
  reason     text         [not null]
  created_by varchar(36)  [not null, ref: > users.user_id]
  expires_at timestamp    [note: 'NULL = không hết hạn']
  is_active  int          [not null, default: 1, note: '1=active 0=disabled']
  created_at timestamp    [not null]

  indexes {
    is_active               [name: 'idx_suppression_active']
    (rule_type, entity_id)  [name: 'idx_suppression_type_eid']
    expires_at              [name: 'idx_supp_expires']
  }
}

Table analyst_reports {
  report_id       varchar(36)   [pk, note: 'UUID']
  title           varchar(255)  [not null]
  report_type     varchar(50)   [not null, note: 'FRAUD_ANALYSIS|LOAN_ANALYSIS|THRESHOLD_RECOMMENDATION|SUPPRESSION_REVIEW|GENERAL']
  content_md      text          [not null, note: 'Nội dung Markdown']
  status          varchar(20)   [not null, note: 'PENDING_REVIEW|ACKNOWLEDGED|ARCHIVED']
  submitted_by    varchar(36)   [not null, ref: > users.user_id, note: 'ANALYST']
  submitted_at    timestamp     [not null]
  acknowledged_by varchar(36)   [ref: > users.user_id, note: 'MANAGER/ADMIN']
  acknowledged_at timestamp
  note            varchar(1000) [note: 'Ghi chú phản hồi của MANAGER']

  indexes {
    status       [name: 'idx_analyst_reports_status']
    submitted_by [name: 'idx_analyst_reports_by']
  }
}

// ============================================================
// GROUP: Reconciliation — Đối soát giao dịch
// ============================================================

TableGroup reconciliation {
  reconciliation_runs
  reconciliation_items
}

Table reconciliation_runs {
  run_id                  varchar(36)   [pk, note: 'UUID']
  period_start            timestamp     [not null]
  period_end              timestamp     [not null]
  status                  varchar(20)   [not null, note: 'RUNNING|COMPLETED|FAILED']
  total_txn_count         int
  matched_count           int
  discrepancy_count       int
  total_amount            decimal(18,2)
  pending_timeout_minutes int           [not null, default: 120]
  error_message           varchar(500)
  triggered_by            varchar(36)   [ref: > users.user_id]
  completed_at            timestamp
  created_at              timestamp     [not null]

  indexes {
    status [name: 'idx_recon_run_status']
  }
}

Table reconciliation_items {
  item_id         varchar(36)   [pk, note: 'UUID']
  run_id          varchar(36)   [not null, ref: > reconciliation_runs.run_id]
  txn_id          varchar(36)   [ref: > transactions_live.txn_id]
  item_type       varchar(50)   [not null, note: 'PENDING_TIMEOUT']
  txn_status      varchar(20)
  txn_amount      decimal(18,2)
  txn_created_at  timestamp
  minutes_pending int
  status          varchar(20)   [not null, default: 'OPEN', note: 'OPEN|RESOLVED']
  resolution_note varchar(500)
  resolved_by     varchar(36)   [ref: > users.user_id]
  resolved_at     timestamp
  created_at      timestamp     [not null]

  indexes {
    run_id [name: 'idx_recon_item_run']
    txn_id [name: 'idx_recon_item_txn']
    status [name: 'idx_recon_item_status']
  }
}

// ============================================================
// GROUP: Operations — ETL, DataLake, Audit, Velocity
// ============================================================

TableGroup operations {
  etl_logs
  datalake_snapshots
  audit_logs
  card_velocity_stats
}

Table etl_logs {
  job_id        varchar(36)  [pk, note: 'UUID']
  job_type      varchar(50)  [not null, note: 'DAILY_SUMMARY']
  target_date   date         [not null]
  status        varchar(20)  [not null, note: 'RUNNING|SUCCESS|FAILED']
  records_in    int
  records_out   int
  error_message varchar(500)
  triggered_by  varchar(36)  [ref: > users.user_id]
  started_at    timestamp    [not null]
  completed_at  timestamp
  created_at    timestamp    [not null]

  indexes {
    job_type    [name: 'idx_etl_logs_type']
    target_date [name: 'idx_etl_logs_date']
    status      [name: 'idx_etl_logs_status']
  }
}

Table datalake_snapshots {
  snapshot_id   varchar(36)   [pk, note: 'UUID']
  snapshot_type varchar(50)   [not null, note: 'DAILY_TXN_SUMMARY|EXTERNAL_INGEST']
  snapshot_date date          [not null]
  job_id        varchar(36)   [ref: > etl_logs.job_id]
  source_label  varchar(100)
  record_count  int           [not null, default: 0]
  total_amount  decimal(18,2)
  data_json     text
  status        varchar(20)   [not null, default: 'ACTIVE', note: 'ACTIVE|ARCHIVED']
  created_at    timestamp     [not null]

  indexes {
    snapshot_type [name: 'idx_datalake_type']
    snapshot_date [name: 'idx_datalake_date']
    status        [name: 'idx_datalake_status']
  }
}

Table audit_logs {
  log_id        varchar(36)  [pk, note: 'UUID']
  event_type    varchar(50)  [not null]
  entity_type   varchar(50)  [not null]
  entity_id     varchar(36)  [not null]
  actor_user_id varchar(36)  [ref: > users.user_id]
  actor_name    varchar(150)
  event_ts      timestamp    [not null]
  detail_json   text

  indexes {
    event_type [name: 'idx_audit_event_type']
    entity_id  [name: 'idx_audit_entity_id']
    event_ts   [name: 'idx_audit_event_ts']
  }
}

Table card_velocity_stats {
  card_hash     varchar(64)   [pk, note: 'SHA256 — không lưu số thẻ raw']
  avg_daily_txn decimal(8,2)  [not null, default: 0]
  total_txn     int           [not null, default: 0]
  avg_amt       decimal(12,2) [not null, default: 0]
  std_amt       decimal(12,2) [not null, default: 0]
  m2_amt        decimal(20,4) [not null, default: 0, note: 'Welford M2 — tính std online']
  distinct_days int           [not null, default: 1]
  last_txn_date varchar(10)
  last_updated  timestamp     [not null]
}

// ============================================================
// GROUP: Data Warehouse — Star Schema
// ============================================================

TableGroup data_warehouse {
  dim_time
  dim_customer
  dim_merchant
  dim_channel
  dim_location
  fact_transactions
  fact_loans
}

Table dim_time {
  time_id     int  [pk]
  full_date   date [not null, unique]
  day_num     int  [not null]
  month_num   int  [not null]
  year_num    int  [not null]
  quarter_num int  [not null]
  is_weekend  int  [not null, note: '0|1']
}

Table dim_customer {
  customer_key int         [pk, increment, note: 'GENERATED AS IDENTITY']
  customer_id  varchar(36) [not null, unique]
  segment      varchar(50)
  risk_level   varchar(20)
  city         varchar(100)
  country      varchar(100)
}

Table dim_merchant {
  merchant_key      int          [pk, increment, note: 'GENERATED AS IDENTITY']
  merchant_id       varchar(36)  [not null, unique]
  merchant_code     varchar(50)
  merchant_name     varchar(150)
  merchant_category varchar(100)
  city              varchar(100)
  country           varchar(100)
  risk_level        varchar(20)
}

Table dim_channel {
  channel_key  int         [pk, increment, note: 'GENERATED AS IDENTITY']
  channel_id   int         [not null, unique]
  channel_code varchar(50)
  channel_name varchar(100)
}

Table dim_location {
  location_key int         [pk, increment, note: 'GENERATED AS IDENTITY']
  source_ip    varchar(64)
  city         varchar(100)
  district     varchar(100)
  country      varchar(100)
}

Table fact_transactions {
  fact_id            varchar(36)   [pk, note: 'UUID']
  txn_id             varchar(36)   [not null, unique, ref: > transactions_live.txn_id]
  time_id            int           [not null, ref: > dim_time.time_id]
  customer_key       int           [not null, ref: > dim_customer.customer_key]
  merchant_key       int           [not null, ref: > dim_merchant.merchant_key]
  channel_key        int           [not null, ref: > dim_channel.channel_key]
  location_key       int           [ref: > dim_location.location_key]
  amount             decimal(18,2) [not null]
  final_status       varchar(20)   [not null]
  fraud_label        int           [note: '0|1']
  manual_review_flag int           [not null, default: 0]
  fraud_score        decimal(6,4)
  processing_time_ms int
  model_version      varchar(50)
  load_ts            timestamp     [not null]
}

Table fact_loans {
  fact_loan_id     varchar(36)   [pk, note: 'UUID']
  loan_id          varchar(36)   [not null, unique, ref: > loans.loan_id]
  time_id          int           [not null, ref: > dim_time.time_id]
  customer_key     int           [not null, ref: > dim_customer.customer_key]
  requested_amount decimal(18,2) [not null]
  final_status     varchar(20)   [not null]
  pd_score         decimal(6,4)
  model_version    varchar(50)
  load_ts          timestamp     [not null]
}
