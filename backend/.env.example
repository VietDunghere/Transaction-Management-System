# ========================================
# Application
# ========================================
APP_NAME="Transaction Management System"
APP_ENV=production           # development | production
DEBUG=false

# ========================================
# Database — Oracle 23ai Free (docker-compose)
# ========================================
# Production (Oracle, kết nối vào container oracle-tms):
DATABASE_URL=oracle+oracledb://tms_user:Tms1234!@localhost:1521/?service_name=FREEPDB1

# Dev fallback — SQLite (không cần Docker):
# DATABASE_URL=sqlite:///./tms.db

# Dev fallback — PostgreSQL:
# DATABASE_URL=postgresql://tms_user:tms_password@localhost:5432/tms_db

# ========================================
# Oracle container credentials
# (dùng cho docker-compose.yml ở project root)
# ========================================
ORACLE_SYS_PASSWORD=Admin1234!
ORACLE_APP_USER=tms_user
ORACLE_APP_PASSWORD=Tms1234!

# ========================================
# JWT Authentication
# ========================================
JWT_SECRET_KEY=change-me-in-production-very-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ========================================
# Fraud Detection Model
# ========================================
FRAUD_MODEL_PATH=./ml_models/fraud_rf_v3.pkl
FRAUD_REJECT_THRESHOLD=0.45
FRAUD_REVIEW_THRESHOLD=0.05
FRAUD_MODEL_VERSION=rf_v3_regularized

# ========================================
# API
# ========================================
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
