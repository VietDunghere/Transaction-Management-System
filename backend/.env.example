# ========================================
# Application
# ========================================
APP_NAME="Transaction Management System"
APP_ENV=development          # development | production
DEBUG=true

# ========================================
# Database
# ========================================
DATABASE_URL=postgresql://tms_user:tms_password@localhost:5432/tms_db
# SQLite (dev fallback, không cần Docker):
# DATABASE_URL=sqlite:///./tms.db

# ========================================
# JWT Authentication
# ========================================
JWT_SECRET_KEY=change-me-in-production-very-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ========================================
# Fraud Detection Model
# ========================================
# Đường dẫn đến file model đã serialize (.pkl)
FRAUD_MODEL_PATH=./ml_models/fraud_rf_v3.pkl
# Threshold từ kết quả evaluation
FRAUD_REJECT_THRESHOLD=0.45
FRAUD_REVIEW_THRESHOLD=0.05
FRAUD_MODEL_VERSION=rf_v3_regularized

# ========================================
# API
# ========================================
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
