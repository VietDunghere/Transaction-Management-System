# ========================================
# Application
# ========================================
APP_NAME="Transaction Management System"
APP_ENV=development
DEBUG=true

# ========================================
# Database — Oracle Free 23ai on FREEPDB1
# ========================================
DATABASE_URL=oracle+oracledb://ADMIN:123456@localhost:1521/?service_name=FREEPDB1

# ========================================
# JWT Authentication
# ========================================
JWT_SECRET_KEY=change-me-in-production-very-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ========================================
# Fraud Detection Model
# ========================================
FRAUD_MODEL_PATH=./ml_models/fraud_rf_v3.pkl
FRAUD_REJECT_THRESHOLD=0.45
FRAUD_REVIEW_THRESHOLD=0.05
FRAUD_MODEL_VERSION=rf_v3_regularized

# ========================================
# API
# ========================================
API_PREFIX=/api/v1
CORS_ORIGINS=
